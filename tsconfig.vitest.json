{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals"],
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@assets/*": ["src/assets/*"],
      "@pages/*": ["src/pages/*"],
      "@ecommerce/*": ["src/ecommerce/*"],
      "@redux/*": ["src/redux/*"],
      "@services/*": ["src/services/*"]
    }
  },
  "include": ["src", "tests"]
}
