{
  "name": "just_code_it",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lintfix": "eslint --fix",
    "preview": "vite preview",
    "format": "prettier --write .",
    "prepare": "husky",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit --pretty",
      "prettier --write"
    ],
    "*.{md,html,css,scss,json}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "@commercetools/platform-sdk": "^8.9.0",
    "@commercetools/sdk-client": "^4.0.1",
    "@commercetools/sdk-middleware-auth": "^8.0.1",
    "@commercetools/sdk-middleware-http": "^8.0.1",
    "@commercetools/ts-client": "^3.3.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^5.0.1",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@mui/x-date-pickers": "^8.3.0",
    "@reduxjs/toolkit": "^2.8.1",
    "axios": "^1.9.0",
    "dayjs": "^1.11.13",
    "motion": "^12.12.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.56.3",
    "react-redux": "^9.2.0",
    "react-router": "^7.6.0",
    "react-toastify": "^11.0.5",
    "swiper": "^11.2.7",
    "uuid": "^11.1.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.27.0",
    "@netlify/vite-plugin-react-router": "^1.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/material-ui": "^0.21.18",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/react-redux": "^7.1.34",
    "@types/react-router": "^5.1.20",
    "@types/swiper": "^5.4.3",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.1.4",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-testing-library": "^7.1.1",
    "eslint-plugin-typescript": "^0.14.0",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.1",
    "prettier": "3.5.3",
    "prettier-plugin-css-order": "^2.1.2",
    "sass-embedded": "^1.87.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.1",
    "vite-plugin-eslint2": "^5.0.3",
    "vitest": "^3.1.4"
  }
}
